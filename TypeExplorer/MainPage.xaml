<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TypeExplorer.MainPage"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout Margin="20" Spacing="10">
        <Label Text="C# Types:"/>
        <Border StrokeThickness="3">
            <CollectionView x:Name="_lstTypes"   
                            Margin="10"
                            SelectionMode="Single"
							SelectionChanged="OnTypeSelected">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                           ItemSpacing="5"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemsSource>
					<x:Array Type="{x:Type x:String}">
						<x:String>int</x:String>
						<x:String>long</x:String>
						<x:String>float</x:String>
						<x:String>double</x:String>
						<x:String>decimal</x:String>
						<x:String>string</x:String>
						<x:String>bool</x:String>
						<x:String>char</x:String>
					</x:Array>
				</CollectionView.ItemsSource>
			</CollectionView>
        </Border>
        <HorizontalStackLayout 
            HorizontalOptions="Center"
			VerticalOptions="Center"
            Margin="0, 10, 0, 0"
			Spacing="20">
            <Label Text="Sample Value:"
			       FontSize="17"
			       VerticalOptions="Center"/>
            <Entry x:Name="_txtSampleValue"
				   Placeholder="Select a type below..." 
			       IsReadOnly="True"
			       FontSize="17"/>
            <Label Text="Size:"
			       VerticalOptions="Center"
			       Margin="20, 0, 0, 0"
			       FontSize="17"/>
            <Entry x:Name="_txtSize" 
			       Placeholder="?" 
			       IsReadOnly="True"
			       FontSize="17"/>
            <Label Text="byte(s)"
			       VerticalOptions="Center"
			       FontSize="17"/>
            <Button Text="Clear"
			        FontSize="17"
			        Margin="20, 0, 0, 0"
			        HorizontalOptions="End"
			        Clicked="OnClearTypeInfo"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
